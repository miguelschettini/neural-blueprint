# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the
# actual URL.
APP_URL="https://ais-dev-53xr3qiltypgrbik3hlb24-222222286975.us-east1.run.app"

# BANCO EFI (GERENCINET) PIX INTEGRATION
# Get these from your Efí Dashboard: https://painel.sejaefi.com.br/
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_PIX_KEY=
# The .p12 certificate file content converted to base64 string
EFI_CERTIFICATE_BASE64=
# Set to 'true' for production, 'false' for sandbox
EFI_SANDBOX=true

# SMTP Configuration for Email Verification
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
JWT_SECRET=
